DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
GUILD_ID=your_guild_id

# Channel IDs
PREDICTIONS_CHANNEL_ID=your_predictions_channel_id
ADMIN_REVIEW_CHANNEL_ID=your_admin_review_channel_id
LEADERBOARD_CHANNEL_ID=your_leaderboard_channel_id

# Role ID for admins who can review/resolve predictions
ADMIN_ROLE_ID=your_admin_role_id

# Max predictions per user per day
MAX_DAILY_PREDICTIONS=3

# NVIDIA NIM API key — powers /setup auto-rate-all (GLM 4.7)
# Get one at https://build.nvidia.com
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key
