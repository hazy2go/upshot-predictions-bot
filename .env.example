DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
GUILD_ID=your_guild_id

# Channel IDs
PREDICTIONS_CHANNEL_ID=your_predictions_channel_id
ADMIN_REVIEW_CHANNEL_ID=your_admin_review_channel_id
LEADERBOARD_CHANNEL_ID=your_leaderboard_channel_id

# Role ID for admins who can review/resolve predictions
ADMIN_ROLE_ID=your_admin_role_id

# Max predictions per user per day
MAX_DAILY_PREDICTIONS=3

# NVIDIA NIM API key — powers /setup auto-rate-all (Llama-4 Maverick)
# Get one at https://build.nvidia.com
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key

# ── Upshot pack sending (/sendpack) ──────────────────────────
# The bot needs your Upshot API Bearer token to send packs. Resolution order:
#   1. UPSHOT_TOKEN_FILE  — path to a JSON file an extractor keeps fresh.
#      Looks for { "accessToken" | "token" | "access_token", "expires_at" }.
#      Expired tokens are ignored. Preferred (auto-refresh, no Discord paste).
#   2. /setup upshot-token — stored in the bot DB (manual fallback).
#   3. UPSHOT_JWT          — static token in env (manual fallback).
# UPSHOT_TOKEN_FILE=./cache/upshot-token.json
#
# Optional: command the bot runs once on a 401/403 to refresh the token file,
# then retries the send. Runs via `/bin/sh -c`.
# UPSHOT_TOKEN_REFRESH_CMD=node scripts/extract-upshot-token.mjs
#
# UPSHOT_JWT=your_upshot_bearer_token
#
# ── Hands-off token (recommended) ────────────────────────────
# Since Upshot uses Google/social login, the bundled extractor logs in via a
# *persistent* browser profile: you sign in once, then it refreshes on its own.
#   1. npm install && npx playwright install chromium
#   2. npm run upshot-login          # opens a window — sign in with Google ONCE
#   3. set UPSHOT_TOKEN_FILE + UPSHOT_TOKEN_REFRESH_CMD above
# After that the bot tops up the token itself — no copy-paste, no snippet.
# Optional overrides:
# UPSHOT_PROFILE_DIR=./cache/upshot-profile
# UPSHOT_APP_URL=https://upshot.cards
