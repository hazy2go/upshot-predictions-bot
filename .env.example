DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id
GUILD_ID=your_guild_id

# Channel IDs
PREDICTIONS_CHANNEL_ID=your_predictions_channel_id
ADMIN_REVIEW_CHANNEL_ID=your_admin_review_channel_id
LEADERBOARD_CHANNEL_ID=your_leaderboard_channel_id

# Role ID for admins who can review/resolve predictions
ADMIN_ROLE_ID=your_admin_role_id

# Max predictions per user per day
MAX_DAILY_PREDICTIONS=3

# NVIDIA NIM API key — powers /setup auto-rate-all (Llama-4 Maverick)
# Get one at https://build.nvidia.com
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key

# ── Upshot pack sending (/sendpack) ──────────────────────────
# The bot needs an Upshot API Bearer token to send packs. Token resolution:
#   1. UPSHOT_TOKEN_FILE  — JSON file the bot keeps fresh itself (preferred).
#      Holds { accessToken, refreshToken, expires_at, ... }. Expired access
#      tokens are ignored; the bot re-mints them automatically (see below).
#   2. /setup upshot-token — stored in the bot DB (manual fallback).
#   3. UPSHOT_JWT          — static token in env (manual fallback).
UPSHOT_TOKEN_FILE=./cache/upshot-token.json
#
# ── Hands-off refresh (recommended — pure HTTP, no browser) ──────────────────
# Upshot's web app stays logged in by POSTing a ROTATING refresh token to
# `POST /api/v1/auth/refresh`. The bot does exactly the same: every 6h (and on a
# 401/403 from a send) it exchanges the stored refresh token for a fresh access
# token and writes the rotated pair back to UPSHOT_TOKEN_FILE. The access token
# lives ~15h and the refresh token is a 7-day sliding window, so as long as the
# bot runs at least weekly it stays authenticated forever — no copy-paste, no
# login, no browser.
#
# Seed it ONCE with a refresh token (grab it from upshot.cards →
# localStorage['global-store'].state.authState.refreshToken, or run upshot-relink):
#   node scripts/upshot-refresh.mjs --refresh-token '<jwt>'
# If the chain ever lapses (bot offline > 7 days), re-link via a real browser:
#   node scripts/upshot-relink.mjs          # opens Chromium; sign in if prompted
#
# UPSHOT_REFRESH_TOKEN=   # optional: seed the very first refresh token via env
#
# ── Browser-extractor fallback (legacy) ──────────────────────────────────────
# Optional command the bot runs on a 401/403 if NO refresh token is available.
# Only needed if /auth/refresh ever stops working. Runs via `/bin/sh -c`.
# UPSHOT_TOKEN_REFRESH_CMD=node scripts/upshot-refresh.mjs
# UPSHOT_PROFILE_DIR=./cache/upshot-profile
# UPSHOT_APP_URL=https://upshot.cards
#
# UPSHOT_JWT=your_upshot_bearer_token
